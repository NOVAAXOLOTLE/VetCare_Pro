<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude session data from cloud backups for security reasons -->
        <exclude domain="file" path="datastore/vetcare_session.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow session transfer between devices during direct setup to improve UX -->
        <include domain="file" path="datastore/vetcare_session.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>